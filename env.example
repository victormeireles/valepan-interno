# Porta do servidor de desenvolvimento
PORT=3001

# ==================== SUPABASE ====================

## Usado no frontend e backend (pode ser público)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

## Usado apenas no backend (NÃO expor no frontend)
SERVICE_ROLE=your-service-role-key-heres

# Google Service Account Credentials (Google Drive — fotos de produção)
# Obtenha essas credenciais no Google Cloud Console
GOOGLE_SA_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# API Key para autenticação de requisições externas na API pública
# ID da pasta raiz onde as fotos serão armazenadas
# Crie a pasta "Valepan-Producao-Embalagem-Fotos" no Google Drive e cole o ID aqui
# IMPORTANTE: Adicione esta variável no arquivo .env.local (não no .env)
GOOGLE_DRIVE_FOLDER_ID=1ABC123DEF456GHI789JKL

# ==================== Z-API (WhatsApp) ====================
ZAPI_INSTANCE_ID=sua-instancia-id
ZAPI_TOKEN=seu-token-aqui
ZAPI_CLIENT_TOKEN=seu-client-token-aqui
ZAPI_BASE_URL=https://api.z-api.io

WHATSAPP_GRUPO_EMBALAGEM=111111111111-group
WHATSAPP_GRUPO_PRODUCAO=111111111111-group
WHATSAPP_GRUPO_FORNO=111111111111-group
WHATSAPP_GRUPO_SAIDAS=111111111111-group

# Painel secreto (sem link no menu): /config/whatsapp
# Controla embalagem, fermentação, forno e saídas via Supabase (interno.whatsapp_notificacoes_config).